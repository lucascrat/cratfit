# Copie este arquivo para .env e preencha com seus valores reais.
# NUNCA commite o arquivo .env com chaves reais.

# Google Maps
VITE_GOOGLE_MAPS_API_KEY=sua_chave_google_maps_aqui

# Google Gemini AI
VITE_GEMINI_API_KEY=sua_chave_gemini_aqui

# Backend API
VITE_API_URL=http://localhost:3000/api/v1

# Sentry (opcional — monitoramento de erros em produção)
# Crie um projeto em https://sentry.io para obter o DSN
VITE_SENTRY_DSN=
